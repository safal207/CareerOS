# CareerOS local MVP configuration

# Backend API port.
PORT=3000

# JSONL waitlist storage path.
CAREEROS_WAITLIST_PATH=data/waitlist.jsonl

# JSONL checkout-intent storage path.
CAREEROS_CHECKOUT_INTENTS_PATH=data/checkout-intents.jsonl

# Optional admin token for protecting GET /api/waitlist and GET /api/checkout-intents.
# Leave empty for local-only MVP validation.
CAREEROS_ADMIN_TOKEN=change-me

# Comma-separated list of frontend origins allowed to call the backend API.
# For GitHub Pages, use: https://safal207.github.io
CAREEROS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Vite dev server port.
VITE_PORT=5173

# Optional remote backend URL for static frontend builds.
# Example: https://careeros-api.onrender.com
VITE_API_BASE_URL=
