{
  "name": "careeros",
  "version": "0.1.0",
  "description": "AI-powered job search operating system for serious job seekers.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck && npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.build.json",
    "build:web": "vite build",
    "smoke:build": "node scripts/smoke-build.mjs",
    "test": "vitest run",
    "ci": "npm run build && npm run smoke:build && npm test",
    "dev": "tsx src/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "start": "node dist/server/server.js",
    "analyze": "tsx src/cli.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
